---
import '../styles/global.css';
import Lightbox from '../components/Lightbox.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Artiste 3D & Illustrateur basé à Bordeaux — personnages, mondes et outils." } = Astro.props;
const canonicalTitle = title === "Accueil" ? "Adriflex" : `${title} — Adriflex`;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{canonicalTitle}</title>

    <!-- Google Fonts : Silkscreen (display) + Space Mono (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Adriflex" href="/rss.xml" />
  </head>
  <body class="bg-bg text-navy font-body min-h-screen flex flex-col">

    <!-- Header -->
    <header id="site-header" class="sticky top-0 z-50 bg-bg border-b-2 border-navy/6 transition-shadow duration-400">
      <div class="max-w-[1120px] mx-auto px-6 md:px-12 py-5 flex justify-between items-center">
        <a href="/" class="font-display text-[32px] font-bold tracking-[2px] hover:text-pink transition-colors duration-200 px-font">
          Adriflex<span class="text-pink animate-[blink_1s_step-end_infinite] ml-[2px]">_</span>
        </a>
        <nav class="flex gap-7">
          <a href="/" class="font-display text-[16px] text-para/40 hover:text-navy transition-colors duration-200 relative group px-font pb-1">
            Projects
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-pink transition-all duration-300 group-hover:w-full"></span>
          </a>
          <a href="/about" class="font-display text-[16px] text-para/40 hover:text-navy transition-colors duration-200 relative group px-font pb-1">
            About
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-pink transition-all duration-300 group-hover:w-full"></span>
          </a>
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <Lightbox />

    <!-- Footer -->
    <footer class="bg-pink py-12">
      <div class="max-w-[1120px] mx-auto px-6 md:px-12 flex flex-col md:flex-row justify-between items-start gap-8">
        <div>
          <!-- Pixel separator -->
          <div class="h-1 w-32 mb-6 image-rendering-pixelated" style="image-rendering:pixelated; background:repeating-linear-gradient(90deg,var(--color-navy) 0px,var(--color-navy) 4px,transparent 4px,transparent 8px);"></div>
          <a href="/" class="font-display text-[24px] font-bold text-navy tracking-[2px] hover:text-white transition-colors duration-200 px-font">
            Adriflex<span class="text-navy/40 animate-[blink_1s_step-end_infinite] ml-[1px]">_</span>
          </a>
          <p class="text-[13px] text-navy mt-3">© {new Date().getFullYear()} Adrien Rouquié — Bordeaux, France</p>
        </div>
        <div class="text-right">
          <div class="flex gap-6 mb-3">
            <a href="https://artstation.com/adriflex" target="_blank" rel="noopener" class="font-display text-[16px] text-navy/65 hover:text-navy transition-colors duration-200 relative group px-font">
              ArtStation
              <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-navy transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="https://instagram.com/adrien.flex" target="_blank" rel="noopener" class="font-display text-[16px] text-navy/65 hover:text-navy transition-colors duration-200 relative group px-font">
              Instagram
              <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-navy transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="https://linkedin.com/in/adrien-rouquie" target="_blank" rel="noopener" class="font-display text-[16px] text-navy/65 hover:text-navy transition-colors duration-200 relative group px-font">
              LinkedIn
              <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-navy transition-all duration-300 group-hover:w-full"></span>
            </a>
            <a href="https://github.com/adriflex" target="_blank" rel="noopener" class="font-display text-[16px] text-navy/65 hover:text-navy transition-colors duration-200 relative group px-font">
              GitHub
              <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-navy transition-all duration-300 group-hover:w-full"></span>
            </a>
          </div>
          <p class="text-[12px] text-navy/45 italic">Des formes vivantes, une lumière qui raconte,<br />un pied dans l'étrange.</p>
        </div>
      </div>
    </footer>

    <!-- Header scroll shadow -->
    <script>
      window.addEventListener('scroll', () => {
        const header = document.getElementById('site-header');
        if (header) {
          header.style.boxShadow = window.scrollY > 10
            ? '0 6px 30px color-mix(in srgb, #001858 6%, transparent)'
            : 'none';
        }
      });
    </script>

  </body>
</html>
