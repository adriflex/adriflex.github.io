---
interface Props {
  title: string;
  description: string;
  slug: string;
  color: string;
  tags: string[];
  featured?: boolean;
  cover?: string;
  status?: string;
  statusLabel?: string;
  collection?: string;
}
const {
  title,
  description,
  slug,
  color,
  tags,
  featured,
  cover,
  status = 'published',
  statusLabel = '',
  collection = 'projects',
} = Astro.props;

const badgeBg: Record<string, string> = {
  wip: '#8BD3DD',
  published: '#F582AE',
  lab: '#F3D2C1',
};
---
<a
  href={`/${collection}/${slug}`}
  class="project-card group block rounded-[2px] overflow-hidden border-2 border-navy bg-bg transition-all duration-300"
  style={`--project-color: ${color};`}
>
  <!-- Image area -->
  <div class="h-[180px] relative overflow-hidden">
    {cover ? (
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
      />
    ) : (
      <>
        <div
          class="absolute inset-0"
          style={`background-color: color-mix(in srgb, ${color} 15%, #FEF6E4);`}
        ></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div
            class="w-32 h-32 rounded-full opacity-20 transition-transform duration-500 group-hover:scale-110"
            style={`background: ${color};`}
          ></div>
        </div>
        <span
          class="absolute inset-0 flex items-center justify-center text-5xl font-display px-font font-bold opacity-30 group-hover:opacity-50 transition-opacity duration-300 select-none"
          style={`color: ${color};`}
        >
          {title.charAt(0)}
        </span>
      </>
    )}

    <!-- Hover overlay -->
    <div class="absolute inset-0 bg-navy/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center pointer-events-none">
      <span class="font-display px-font text-[16px] text-white tracking-[4px] border-2 border-white px-5 py-2 rounded-[2px]">View</span>
    </div>

    <!-- Status badge -->
    {statusLabel && (
      <span
        class="absolute top-3 right-3 font-display px-font text-[8px] px-3 py-1 rounded-[2px] text-navy z-10"
        style={`background-color: ${badgeBg[status] || '#F582AE'};`}
      >
        {statusLabel}
      </span>
    )}
  </div>

  <!-- Card body -->
  <div class="relative p-5">
    <h3 class="font-display px-font text-[16px] font-bold text-navy group-hover:text-pink transition-colors duration-200 pr-6">
      {title}
    </h3>
    <p class="text-[13px] text-para mb-[14px] line-clamp-2 font-body leading-relaxed">
      {description}
    </p>
    <div class="flex gap-1.5 flex-wrap">
      {tags.map(tag => (
        <span
          class="font-display px-font text-[8px] px-[10px] py-1 rounded-[2px] border border-navy/9 text-navy/50"
          data-card-tag={tag}
        >
          {tag}
        </span>
      ))}
    </div>

    <!-- Arrow -->
    <span class="absolute top-5 right-5 font-display px-font text-[16px] text-pink opacity-0 -translate-x-[10px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 pointer-events-none">
      →
    </span>
  </div>
</a>

<style>
  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: 6px 6px 0 color-mix(in srgb, #001858 8%, transparent);
  }

  .project-card:active {
    transform: translateY(-4px) scale(0.99);
  }
</style>
