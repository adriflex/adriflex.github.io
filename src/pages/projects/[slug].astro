---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Lightbox from '../../components/Lightbox.astro';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection('projects');
  return projects.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const slug = entry.id.replace(/\.md$/, '');
const ogImage = new URL(`og/projects/${slug}.png`, Astro.site).href;
const schema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": entry.data.title,
  "description": entry.data.description,
  "url": Astro.url.href,
  "image": ogImage,
  "dateCreated": entry.data.date.toISOString().split('T')[0],
  "keywords": entry.data.tags.join(', '),
  "author": { "@type": "Person", "name": "Adrien Rouquié", "url": "https://adriflex.github.io" },
};
---
<Base title={entry.data.title} description={entry.data.description} ogImage={ogImage} schema={schema}>
  <article>
    <div class="max-w-[1120px] mx-auto px-6 md:px-12 py-12">

      <!-- Retour -->
      <a href="/" class="inline-flex items-center gap-2 font-display px-font text-[16px] text-pink hover:text-navy hover:-translate-x-1.5 transition-all duration-200 mb-8">
        ← Retour
      </a>

      <!-- Cover image — full container width -->
      {entry.data.coverFull ? (
        <div class="rounded-[2px] border-2 border-navy overflow-hidden mb-10">
          {entry.data.cover && (
            <img src={entry.data.cover} alt={entry.data.title} class="w-full h-auto lightbox-trigger cursor-zoom-in" />
          )}
        </div>
      ) : (
        <div
          class="rounded-[2px] border-2 border-navy relative overflow-hidden flex items-center justify-center mb-10"
          style={`height: clamp(240px, 35vw, 400px); background-color: color-mix(in srgb, ${entry.data.color} 15%, var(--color-bg));`}
        >
          {entry.data.cover ? (
            <img src={entry.data.cover} alt={entry.data.title} class="w-full h-full object-cover lightbox-trigger cursor-zoom-in absolute inset-0" />
          ) : (
            <>
              <div class="absolute w-40 h-40 rounded-full opacity-15" style={`background: ${entry.data.color};`}></div>
              <span class="relative font-display px-font text-7xl font-bold opacity-25 select-none" style={`color: ${entry.data.color};`}>
                {entry.data.title.charAt(0)}
              </span>
            </>
          )}
        </div>
      )}

      <!-- Titre -->
      <h1 class="font-display px-font text-[32px] font-bold text-navy leading-[1.5] mb-4">{entry.data.title}</h1>

      <!-- Description -->
      <p class="font-body text-[15px] text-para/60 leading-[1.85] mb-6 max-w-[720px]">{entry.data.description}</p>

      <!-- Date + badge statut -->
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <time class="font-body text-[13px] text-para/40">
          {new Date(entry.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {entry.data.status === 'wip' && (
          <span class="font-display px-font text-[8px] px-3 py-1 rounded-[2px] bg-accent text-navy">
            En cours
          </span>
        )}
        {entry.data.status === 'published' && (
          <span class="font-display px-font text-[8px] px-3 py-1 rounded-[2px] bg-pink text-navy">
            Publié
          </span>
        )}
      </div>

      <!-- Tags -->
      <div class="flex gap-2 flex-wrap mb-8">
        {entry.data.tags.map(tag => (
          <span class="font-display px-font text-[8px] px-3 py-1 rounded-[2px] border border-navy/15 text-navy/60">
            {tag}
          </span>
        ))}
      </div>

      <!-- CTA si lien externe -->
      {entry.data.link && (
        <a
          href={entry.data.link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-pink text-navy font-display px-font text-[16px] rounded-[2px] transition-all duration-200 hover:shadow-[4px_4px_0_rgba(245,130,174,0.3)] hover:-translate-y-0.5 mb-10"
        >
          {entry.data.ctaLabel || 'Voir le projet ↗'}
        </a>
      )}

      <!-- CTA PDF haut de page -->
      {entry.data.pdfDownload && (
        <a
          href={entry.data.pdfDownload}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-pink text-navy font-display px-font text-[16px] rounded-[2px] transition-all duration-200 hover:shadow-[4px_4px_0_rgba(245,130,174,0.3)] hover:-translate-y-0.5 mb-10"
        >
          ↓ Lire la BD (PDF)
        </a>
      )}

      <!-- Viewer PDF -->
      {entry.data.pdf && (
        <div class="mb-6">
          <div class="rounded-[2px] overflow-hidden border-2 border-navy" style="aspect-ratio: 3/4; min-height: 500px;">
            <iframe src={entry.data.pdf} width="100%" height="100%" allow="autoplay" class="w-full h-full" />
          </div>
        </div>
      )}

      <!-- Séparateur pixel -->
      <div class="px-sep mb-10"></div>

      <div class="lg:grid lg:grid-cols-[minmax(0,720px)_240px] lg:gap-12 lg:items-start">
        <!-- Contenu Markdown -->
        <div id="project-content" class="prose prose-neutral max-w-[720px] font-body text-[15px]
          prose-headings:font-display prose-headings:font-bold prose-headings:text-navy
          prose-h2:text-[24px] prose-h2:leading-[1.35] prose-h2:mt-14 prose-h2:mb-5
          prose-h3:font-body prose-h3:text-[16px] prose-h3:leading-[1.6] prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-para
          prose-p:text-para prose-p:leading-[1.85]
          prose-a:text-pink prose-a:no-underline prose-a:hover:underline prose-a:underline-offset-4
          prose-strong:text-navy
          prose-img:rounded-[2px] prose-img:border-2 prose-img:border-navy">
          <Content />
        </div>

        <aside id="project-toc-wrap" class="hidden lg:block sticky top-8 self-start border-l-2 border-navy/10 pl-5 pr-2 max-h-[calc(100vh-4rem)] overflow-y-auto overflow-x-hidden">
          <p class="font-display px-font text-[8px] text-navy/40 uppercase tracking-[3px] mb-4">On this page</p>
          <nav id="project-toc" class="flex flex-col gap-2"></nav>
        </aside>
      </div>


    </div>
  </article>
  <Lightbox />

  <script>
    const content = document.getElementById('project-content');
    const toc = document.getElementById('project-toc');
    const tocWrap = document.getElementById('project-toc-wrap');

    if (content && toc && tocWrap) {
      const slugify = (text: string) => text
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');

      const headings = Array.from(content.querySelectorAll('h2, h3')) as HTMLHeadingElement[];
      const usedIds = new Set<string>();

      headings.forEach((heading) => {
        const base = heading.id || slugify(heading.textContent || 'section');
        let id = base;
        let index = 2;

        while (usedIds.has(id) || (document.getElementById(id) && document.getElementById(id) !== heading)) {
          id = `${base}-${index}`;
          index += 1;
        }

        heading.id = id;
        usedIds.add(id);

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent || '';
        link.dataset.headingId = id;
        link.className = heading.tagName === 'H2'
          ? 'toc-link toc-link-h2'
          : 'toc-link toc-link-h3';
        toc.appendChild(link);
      });

      if (headings.length < 3) {
        tocWrap.remove();
      }

      const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('a'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          links.forEach((link) => {
            link.toggleAttribute('data-active', link.dataset.headingId === entry.target.id);
          });
        });
      }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });

      headings.forEach((heading) => observer.observe(heading));
    }
  </script>

  <style>
    :global(html) {
      scroll-behavior: smooth;
    }

    :global(#project-content h2),
    :global(#project-content h3) {
      scroll-margin-top: 24px;
    }

    :global(#project-content h3) {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: auto;
      text-rendering: auto;
    }

    :global(.toc-link) {
      display: block;
      color: color-mix(in srgb, var(--color-para) 62%, transparent);
      line-height: 1.45;
      text-decoration: none;
      transition: color 160ms ease, transform 160ms ease;
    }

    :global(.toc-link:hover),
    :global(.toc-link[data-active]) {
      color: var(--color-pink);
    }

    :global(.toc-link-h2) {
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0;
      margin-top: 8px;
    }

    :global(.toc-link-h3) {
      font-family: var(--font-body);
      font-size: 12px;
      padding-left: 12px;
    }
  </style>
</Base>
