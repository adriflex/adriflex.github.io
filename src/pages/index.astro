---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const allLab = await getCollection('lab');

// Astro 5 uses entry.id (e.g. "orb-of-avarice.md") — strip extension for URL slug
const toSlug = (id: string) => id.replace(/\.md$/, '');

const publishedProjects = allProjects
  .filter(p => p.data.status !== 'archived')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allLabSorted = allLab
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Accueil">

  <!-- Hero -->
  <section class="px-6 pt-20 pb-16 max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row items-center gap-12">

      <!-- Texte -->
      <div class="flex flex-col gap-6 flex-1">
        <!-- Tag métier -->
        <div class="flex items-center gap-2">
          <span class="w-8 h-px bg-accent"></span>
          <span class="text-sm font-body text-accent font-medium tracking-wide uppercase">Artiste 3D & Illustrateur</span>
        </div>

        <!-- Titre principal -->
        <h1 class="font-display text-[clamp(2rem,4vw,3.75rem)] font-bold leading-[1.05] tracking-tight text-ink">
          Personnages.<br />
          <span class="text-accent">Mondes.</span><br />
          Outils.
        </h1>

        <!-- Sous-titre -->
        <p class="font-body text-lg text-ink/60 max-w-md leading-relaxed">
          Je crée des univers stylisés, des jeux, des outils Blender et des apps.
          Basé à Bordeaux, en télétravail pour le monde.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 pt-2">
          <a
            href="/projects"
            class="inline-flex items-center gap-2 px-6 py-3 bg-ink text-cream font-body font-medium rounded-full hover:bg-accent transition-colors duration-300 text-sm"
          >
            Voir les projets
          </a>
          <a
            href="https://artstation.com/adriflex"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 border border-ink/20 text-ink font-body font-medium rounded-full hover:border-accent hover:text-accent transition-colors duration-300 text-sm"
          >
            ArtStation ↗
          </a>
        </div>
      </div>

      <!-- Grille 3 images asymétrique -->
      <div class="grid grid-cols-[3fr_2fr] grid-rows-2 gap-2 h-[280px] sm:h-[360px] md:h-[460px] md:w-[500px] w-full shrink-0">
        <!-- Illustration pleine hauteur (colonne gauche, 2 lignes) -->
        <div class="row-span-2 overflow-hidden rounded-xl border border-ink/8 group cursor-zoom-in">
          <img
            src="/images/hero-illustration.png"
            alt="Illustration — oiseau survolant une ville"
            class="lightbox-trigger w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <!-- Personnage 3D (colonne droite, ligne 1) -->
        <div class="overflow-hidden rounded-xl border border-ink/8 group cursor-zoom-in">
          <img
            src="/images/hero-3d.jpg"
            alt="Personnage 3D stylisé — archère au chignon"
            class="lightbox-trigger w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <!-- Orb of Avarice (colonne droite, ligne 2) -->
        <div class="overflow-hidden rounded-xl border border-ink/8 group cursor-zoom-in">
          <img
            src="/images/hero-game.png"
            alt="Orb of Avarice — jeu vidéo isométrique"
            class="lightbox-trigger w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- Séparateur -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="h-px bg-ink/8"></div>
  </div>

  <!-- Projets mis en avant -->
  <section class="px-6 py-14 max-w-5xl mx-auto">
    <div class="mb-8">
      <h2 class="font-display text-2xl font-bold">Projets</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {publishedProjects.map(p => (
        <ProjectCard
          title={p.data.title}
          description={p.data.description}
          slug={toSlug(p.id)}
          color={p.data.color}
          tags={p.data.tags}
          featured={p.data.featured}
          cover={p.data.cover}
        />
      ))}
    </div>
  </section>

  <!-- Séparateur -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="h-px bg-ink/8"></div>
  </div>

  <!-- Lab -->
  <section class="px-6 py-14 max-w-5xl mx-auto">
    <div class="mb-8">
      <h2 class="font-display text-2xl font-bold">Lab</h2>
    </div>
    <ul>
      {allLabSorted.map((post, i) => (
        <li class={i < allLabSorted.length - 1 ? 'border-b border-ink/8' : ''}>
          <a
            href={`/lab/${toSlug(post.id)}`}
            class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1 sm:gap-4 py-5 group hover:text-accent transition-colors duration-200"
          >
            <div class="flex-1 min-w-0">
              <span class="font-body font-medium group-hover:underline underline-offset-4 decoration-accent block">
                {post.data.title}
              </span>
              {post.data.tags.length > 0 && (
                <div class="flex gap-1.5 mt-1 flex-wrap">
                  {post.data.tags.map(tag => (
                    <span class="text-xs text-ink/40 font-body">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="flex items-center gap-3 sm:gap-4 shrink-0 mt-2 sm:mt-0">
              {post.data.cover && (
                <img
                  src={post.data.cover}
                  alt={post.data.title}
                  class="hidden sm:block w-20 h-14 object-cover rounded-md opacity-80 group-hover:opacity-100 transition-opacity duration-200"
                />
              )}
              <span class="text-xs sm:text-sm font-body text-ink/40 group-hover:text-accent transition-colors duration-200">
                {new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</Base>
