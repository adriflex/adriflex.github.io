---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const allLab = await getCollection('lab');

const toSlug = (id: string) => id.replace(/\.md$/, '');

// Merge all items into a single list with unified shape
type CardItem = {
  title: string;
  description: string;
  slug: string;
  color: string;
  tags: string[];
  featured: boolean;
  cover?: string;
  status: string;
  statusLabel: string;
  collection: string;
  date: Date;
};

const allItems: CardItem[] = [
  ...allProjects.filter(p => p.data.status !== 'archived').map(p => ({
    title: p.data.title,
    description: p.data.description,
    slug: toSlug(p.id),
    color: p.data.color,
    tags: p.data.tags,
    featured: p.data.featured,
    cover: p.data.cover,
    status: p.data.status,
    statusLabel: p.data.status === 'wip' ? 'En cours' : 'Publié',
    collection: 'projects',
    date: p.data.date,
  })),
  ...allLab.map(p => ({
    title: p.data.title,
    description: '',
    slug: toSlug(p.id),
    color: '#7c3aed',
    tags: p.data.tags,
    featured: false,
    cover: p.data.cover,
    status: 'lab',
    statusLabel: 'Lab',
    collection: 'lab',
    date: p.data.date,
  })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

// Group by year
const itemsByYear: Record<number, CardItem[]> = {};
allItems.forEach(item => {
  const year = item.date.getFullYear();
  if (!itemsByYear[year]) itemsByYear[year] = [];
  itemsByYear[year].push(item);
});
const years = Object.keys(itemsByYear).map(Number).sort((a, b) => b - a);

// Collect all unique tags
const allTags = [
  ...new Set([
    ...allProjects.filter(p => p.data.status !== 'archived').flatMap(p => p.data.tags),
    ...allLab.flatMap(p => p.data.tags),
  ])
].sort();

// Count per tag
const tagCounts: Record<string, number> = {};
allTags.forEach(tag => {
  tagCounts[tag] = [
    ...allProjects.filter(p => p.data.status !== 'archived' && p.data.tags.includes(tag)),
    ...allLab.filter(p => p.data.tags.includes(tag)),
  ].length;
});
---
<Base title="Accueil">

  <section>
  <div class="max-w-[1120px] mx-auto px-6 md:px-12">

    <!-- Tag Cloud -->
    <section class="pt-12 pb-7">
      <div class="flex items-center gap-3 mb-4">
        <p class="text-[12px] text-para/40 italic opacity-0 animate-[fadeSlideLeft_0.4s_ease_0.3s_forwards]">Filtrer par —</p>
        <button id="toggle-tags" class="md:hidden font-display text-[10px] text-pink border border-pink/40 px-3 py-1 rounded-[2px] px-font opacity-0 animate-[fadeSlideLeft_0.4s_ease_0.4s_forwards]">
          Afficher les tags ▾
        </button>
      </div>
      <div class="hidden md:flex gap-[6px] md:gap-[10px] flex-wrap" id="tag-cloud">
        {allTags.map((tag, i) => (
          <button
            data-tag={tag}
            class="tag-btn font-display text-[10px] md:text-[16px] font-normal px-[10px] py-[5px] md:px-[18px] md:py-[8px] rounded-[2px] cursor-pointer
                   border-2 border-navy/12 text-navy/67 bg-transparent
                   transition-all duration-250 select-none relative overflow-hidden
                   hover:border-accent hover:text-navy hover:-translate-y-0.5
                   hover:shadow-[0_4px_12px_color-mix(in_srgb,#8BD3DD_15%,transparent)]
                   px-font opacity-0 animate-[fadeSlideUp_0.4s_ease_forwards]"
            style={`animation-delay: ${0.35 + i * 0.04}s`}
          >
            #{tag}<span class="tag-count font-body text-[8px] md:text-[10px] text-pink ml-1 md:ml-1.5 opacity-0 transition-opacity duration-200 inline-block translate-y-0.5">{tagCounts[tag]}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Pixel separator -->
    <div class="px-sep mb-7"></div>

    <!-- Filter info -->
    <div id="filter-info" class="text-[13px] text-para/45 mb-6 min-h-[22px]">
      <span class="text-pink font-bold">{allItems.length}</span> projets
    </div>

    <!-- Grid by year -->
    {years.map((year, yi) => (
      <div data-section={`year-${year}`}>
        <div class="font-display text-[8px] font-normal text-para/30 uppercase tracking-[3px] mb-5 flex items-center gap-4 px-font" style={yi > 0 ? 'margin-top: 2.5rem;' : ''}>
          {year}
          <span class="flex-1 h-px bg-navy/6"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
          {itemsByYear[year].map((item, i) => (
            <div class="card-wrapper opacity-0 animate-[fadeSlideUp_0.5s_ease_forwards]" style={`animation-delay: ${0.5 + (yi * 3 + i) * 0.06}s`} data-tags={item.tags.join(',')}>
              <ProjectCard
                title={item.title}
                description={item.description}
                slug={item.slug}
                color={item.color}
                tags={item.tags}
                featured={item.featured}
                cover={item.cover}
                status={item.status}
                statusLabel={item.statusLabel}
                collection={item.collection}
              />
            </div>
          ))}
        </div>
      </div>
    ))}

  </div>
  </section>

  <!-- Client-side tag filtering -->
  <script>
    // Mobile tag cloud toggle
    const toggleTagsBtn = document.getElementById('toggle-tags');
    const tagCloud = document.getElementById('tag-cloud');
    if (toggleTagsBtn && tagCloud) {
      toggleTagsBtn.addEventListener('click', () => {
        const isHidden = tagCloud.classList.contains('hidden');
        if (isHidden) {
          tagCloud.classList.remove('hidden');
          tagCloud.classList.add('flex');
          toggleTagsBtn.textContent = 'Masquer les tags ▴';
          tagCloud.querySelectorAll('.tag-btn').forEach(btn => {
            (btn as HTMLElement).style.opacity = '1';
            (btn as HTMLElement).style.animation = 'none';
          });
        } else {
          tagCloud.classList.add('hidden');
          tagCloud.classList.remove('flex');
          toggleTagsBtn.textContent = 'Afficher les tags ▾';
        }
      });
    }

    let activeTag: string | null = null;

    const tagBtns = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const cards = document.querySelectorAll<HTMLElement>('.card-wrapper');
    const sections = document.querySelectorAll<HTMLElement>('[data-section]');
    const filterInfo = document.getElementById('filter-info');
    const totalCount = cards.length;

    // After entrance animations finish, strip animation classes so inline styles work
    setTimeout(() => {
      cards.forEach(wrapper => {
        wrapper.style.animation = 'none';
        wrapper.style.opacity = '1';
      });
      tagBtns.forEach(btn => {
        btn.style.animation = 'none';
        btn.style.opacity = '1';
      });
    }, 2000);

    function updateFilter() {
      tagBtns.forEach(btn => {
        const tag = btn.dataset.tag!;
        const isActive = activeTag === tag;

        if (isActive) {
          btn.style.borderColor = '#001858';
          btn.style.color = '#001858';
          btn.style.backgroundColor = 'rgba(139, 211, 221, 0.25)';
          btn.style.boxShadow = '3px 3px 0 rgba(0, 24, 88, 0.1)';
        } else {
          btn.style.borderColor = '';
          btn.style.color = '';
          btn.style.backgroundColor = '';
          btn.style.boxShadow = '';
        }

        const countEl = btn.querySelector('.tag-count') as HTMLElement;
        if (countEl) {
          countEl.style.opacity = isActive ? '1' : '0';
        }
      });

      let visibleCount = 0;
      cards.forEach(wrapper => {
        const cardTags = (wrapper.dataset.tags || '').split(',');
        const isMatch = !activeTag || cardTags.includes(activeTag);

        if (isMatch) {
          wrapper.style.opacity = '1';
          wrapper.style.transform = '';
          wrapper.style.filter = '';
          wrapper.style.pointerEvents = '';
          visibleCount++;
        } else {
          wrapper.style.opacity = '0.12';
          wrapper.style.transform = 'scale(0.96)';
          wrapper.style.filter = 'grayscale(0.4)';
          wrapper.style.pointerEvents = 'none';
        }
        wrapper.style.transition = 'opacity 0.35s ease, transform 0.35s ease, filter 0.35s ease';
      });

      // Hide empty year sections
      sections.forEach(section => {
        const sectionCards = section.querySelectorAll<HTMLElement>('.card-wrapper');
        let hasVisible = false;
        sectionCards.forEach(c => {
          const tags = (c.dataset.tags || '').split(',');
          if (!activeTag || tags.includes(activeTag)) hasVisible = true;
        });
        section.style.display = hasVisible ? '' : 'none';
      });

      if (filterInfo) {
        if (!activeTag) {
          filterInfo.innerHTML = `<span style="color:#F582AE;font-weight:700;">${totalCount}</span> projets`;
        } else {
          filterInfo.innerHTML = `<span style="color:#F582AE;font-weight:700;">${visibleCount}</span> projet${visibleCount > 1 ? 's' : ''} en <span style="color:#F582AE;font-weight:700;">#${activeTag}</span> <button id="clear-filter" style="font-family:Silkscreen,sans-serif;font-size:8px;color:#F582AE;cursor:pointer;margin-left:8px;border:1px solid rgba(245,130,174,0.4);padding:2px 8px;border-radius:2px;background:transparent;">✕ clear</button>`;
          document.getElementById('clear-filter')?.addEventListener('click', () => {
            activeTag = null;
            updateFilter();
          });
        }
      }
    }

    tagBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag!;
        activeTag = activeTag === tag ? null : tag;
        updateFilter();
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.dataset.cardTag) {
        e.preventDefault();
        e.stopPropagation();
        const tag = target.dataset.cardTag;
        activeTag = activeTag === tag ? null : tag;
        updateFilter();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
  </script>

</Base>
