---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import Lightbox from '../../components/Lightbox.astro';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('lab');
  return posts.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await entry.render();
const slug = entry.id.replace(/\.md$/, '');
const ogImage = new URL(`og/lab/${slug}.png`, Astro.site).href;
const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "url": Astro.url.href,
  "image": ogImage,
  "datePublished": entry.data.date.toISOString().split('T')[0],
  "keywords": entry.data.tags.join(', '),
  "author": { "@type": "Person", "name": "Adrien Rouquié", "url": "https://adriflex.github.io" },
};
---
<Base title={entry.data.title} ogImage={ogImage} schema={schema}>
  <article>
    <div class="max-w-[1120px] mx-auto px-6 md:px-12 py-12">

      <!-- Retour -->
      <a href="/" class="inline-flex items-center gap-2 font-display px-font text-[16px] text-pink hover:text-navy hover:-translate-x-1.5 transition-all duration-200 mb-8">
        ← Retour
      </a>

      <!-- Cover image — full container width -->
      {entry.data.cover && entry.data.coverFull && (
        <div class="rounded-[2px] border-2 border-navy overflow-hidden mb-10">
          <img src={entry.data.cover} alt={entry.data.title} class="w-full h-auto lightbox-trigger cursor-zoom-in" />
        </div>
      )}
      {entry.data.cover && !entry.data.coverFull && (
        <div class="rounded-[2px] border-2 border-navy overflow-hidden mb-10" style="height: clamp(200px, 30vw, 360px);">
          <img src={entry.data.cover} alt={entry.data.title} class="w-full h-full object-cover lightbox-trigger cursor-zoom-in" style={`object-position: ${entry.data.coverPosition};`} />
        </div>
      )}

      <!-- Titre -->
      <h1 class="font-display px-font text-[32px] font-bold text-navy leading-[1.5] mb-4">{entry.data.title}</h1>

      <!-- Date -->
      <time class="font-body text-[13px] text-para/40 block mb-4">
        {new Date(entry.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
      </time>

      <!-- Badge + Tags -->
      <div class="flex items-center gap-2 mb-8 flex-wrap">
        <span class="font-display px-font text-[8px] px-3 py-1 rounded-[2px] bg-peach text-navy">
          Lab
        </span>
        {entry.data.tags.map(tag => (
          <span class="font-display px-font text-[8px] px-3 py-1 rounded-[2px] border border-navy/15 text-navy/60">
            {tag}
          </span>
        ))}
      </div>

      <!-- Séparateur pixel -->
      <div class="px-sep mb-10"></div>

      <div class="lg:grid lg:grid-cols-[minmax(0,720px)_240px] lg:gap-12 lg:items-start">
        <!-- Contenu Markdown -->
        <div id="lab-content" class="prose prose-neutral max-w-[720px] font-body text-[15px]
          prose-headings:font-display prose-headings:font-bold prose-headings:text-navy
          prose-h2:text-[16px] prose-h3:text-[16px]
          prose-p:text-para prose-p:leading-[1.85]
          prose-a:text-pink prose-a:no-underline prose-a:hover:underline prose-a:underline-offset-4
          prose-strong:text-navy
          prose-img:rounded-[2px] prose-img:border-2 prose-img:border-navy">
          <Content />
        </div>

        <aside id="lab-toc-wrap" class="hidden lg:block sticky top-8 self-start border-l-2 border-navy/10 pl-5 pr-2 max-h-[calc(100vh-4rem)] overflow-y-auto overflow-x-hidden">
          <p class="font-display px-font text-[8px] text-navy/40 uppercase tracking-[3px] mb-4">On this page</p>
          <nav id="lab-toc" class="flex flex-col gap-2"></nav>
        </aside>
      </div>

    </div>
  </article>
  <Lightbox />

  <script>
    const content = document.getElementById('lab-content');
    const toc = document.getElementById('lab-toc');
    const tocWrap = document.getElementById('lab-toc-wrap');

    if (content && toc && tocWrap) {
      const slugify = (text: string) => text
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');

      const headings = Array.from(content.querySelectorAll('h2, h3')) as HTMLHeadingElement[];
      const usedIds = new Set<string>();

      headings.forEach((heading) => {
        const base = heading.id || slugify(heading.textContent || 'section');
        let id = base;
        let index = 2;

        while (usedIds.has(id) || (document.getElementById(id) && document.getElementById(id) !== heading)) {
          id = `${base}-${index}`;
          index += 1;
        }

        heading.id = id;
        usedIds.add(id);

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent || '';
        link.dataset.headingId = id;
        link.className = heading.tagName === 'H2'
          ? 'toc-link toc-link-h2'
          : 'toc-link toc-link-h3';
        toc.appendChild(link);
      });

      if (headings.length < 3) {
        tocWrap.remove();
      }

      const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('a'));
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          links.forEach((link) => {
            link.toggleAttribute('data-active', link.dataset.headingId === entry.target.id);
          });
        });
      }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });

      headings.forEach((heading) => observer.observe(heading));
    }
  </script>

  <style>
    :global(html) {
      scroll-behavior: smooth;
    }

    :global(#lab-content h2),
    :global(#lab-content h3) {
      scroll-margin-top: 24px;
    }

    :global(.toc-link) {
      display: block;
      color: color-mix(in srgb, var(--color-para) 62%, transparent);
      line-height: 1.45;
      text-decoration: none;
      transition: color 160ms ease, transform 160ms ease;
    }

    :global(.toc-link:hover),
    :global(.toc-link[data-active]) {
      color: var(--color-pink);
    }

    :global(.toc-link-h2) {
      font-family: var(--font-display);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0;
      margin-top: 8px;
    }

    :global(.toc-link-h3) {
      font-family: var(--font-body);
      font-size: 12px;
      padding-left: 12px;
    }
  </style>
</Base>
